# ===== Enoch & Enoch Legal — environment variables =====
# Copy these into your NEW Railway project's "Variables" tab.
# Railway sets PORT automatically — do NOT add it yourself.

# --- MongoDB (REQUIRED) ---
# 👉 TO RECOVER YOUR PREVIOUS POSTS, IMAGES & MESSAGES: point MONGODB_URI at the
#    SAME Atlas cluster you used before. All old data is still there — the app reads
#    whatever database you connect to (it only seeds a starter post when EMPTY, so it
#    never overwrites your existing content).
#
# Your existing cluster (fill in the real password, replacing <db_password>):
MONGODB_URI=mongodb+srv://tayo112113:<db_password>@cluster0.pakyqci.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
# MUST match the database name your old data lives in (default for this app is "enochlegal").
# If your previous posts don't appear, open Atlas → Browse Collections and use that DB name here.
MONGODB_DB_NAME=enochlegal

# --- Admin login (optional) ---
# Password-only. A 450-digit default is baked into the code; set this on Railway to rotate.
ADMIN_PASSWORD=your-450-digit-access-code

# --- Cloudinary (blog cover-image uploads) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Email for contact-form notifications (optional) ---
# Messages are ALWAYS saved to the database; email is just a bonus notification.
# Use a Gmail App Password (not your normal password).
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password
